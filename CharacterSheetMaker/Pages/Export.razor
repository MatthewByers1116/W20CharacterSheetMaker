@page "/export"
@using W20Builder.Models
@using System.Text.Json
@inject CharacterBuilderService BuilderService
@inject IJSRuntime JS

<PageTitle>W20 Builder - Final Export</PageTitle>

<div class="character-panel no-print">
    <div class="export-actions">
        <button class="btn-terminal" @onclick="PrintSheet">PRINT PHYSICAL RECORD</button>
        <button class="btn-terminal" @onclick="DownloadJson">DOWNLOAD DATA ARCHIVE (.JSON)</button>
    </div>
</div>

<div class="printable-sheet scanline-bg">
    <div class="sheet-header">
        <h1>GAROU IDENTITY RECORD: @character.Name.ToUpper()</h1>
        <div class="header-grid">
            <p><strong>PLAYER:</strong> @character.Player</p>
            <p><strong>CHRONICLE:</strong> @character.Chronicle</p>
            <p><strong>CONCEPT:</strong> @character.Concept</p>
            <p><strong>BREED:</strong> @character.Breed</p>
            <p><strong>AUSPICE:</strong> @character.Auspice</p>
            <p><strong>TRIBE:</strong> @character.Tribe</p>
        </div>
    </div>

    <div class="sheet-section">
        <h3>ATTRIBUTES</h3>
        <div class="triple-grid">
            <div class="col">
                <p>Strength: @character.Strength</p>
                <p>Dexterity: @character.Dexterity</p>
                <p>Stamina: @character.Stamina</p>
            </div>
            <div class="col">
                <p>Charisma: @character.Charisma</p>
                <p>Manipulation: @character.Manipulation</p>
                <p>Appearance: @character.Appearance</p>
            </div>
            <div class="col">
                <p>Perception: @character.Perception</p>
                <p>Intelligence: @character.Intelligence</p>
                <p>Wits: @character.Wits</p>
            </div>
        </div>
    </div>

    <div class="sheet-section">
        <h3>ABILITIES</h3>
        <div class="triple-grid">
            <div class="col">
                @foreach(var talent in character.Talents.Where(t => t.Value > 0)) { <p>@talent.Key: @talent.Value</p> }
            </div>
            <div class="col">
                @foreach(var skill in character.Skills.Where(s => s.Value > 0)) { <p>@skill.Key: @skill.Value</p> }
            </div>
            <div class="col">
                @foreach(var know in character.Knowledges.Where(k => k.Value > 0)) { <p>@know.Key: @know.Value</p> }
            </div>
        </div>
    </div>

    <div class="sheet-section">
        <h3>ADVANTAGES</h3>
        <div class="double-grid">
            <div class="col">
                <h4>BACKGROUNDS</h4>
                @foreach(var bg in character.Backgrounds.Where(b => b.Value > 0)) { <p>@bg.Key: @bg.Value</p> }
            </div>
            <div class="col">
                <h4>RENOWN (STARTING)</h4>
                <p>Glory: @character.Glory</p>
                <p>Honor: @character.Honor</p>
                <p>Wisdom: @character.Wisdom</p>
            </div>
        </div>
    </div>

    <div class="sheet-section">
        <h3>MANIFESTED GIFTS</h3>
        <div class="gift-list">
            @foreach (var gift in character.SelectedGifts.Concat(character.FreebieGifts).Where(g => !string.IsNullOrEmpty(g)))
            {
                <span class="gift-tag">[@gift.ToUpper()]</span>
            }
        </div>
    </div>

    <div class="sheet-section stats-footer">
        <div class="stat-box">RAGE: @character.TotalRage</div>
        <div class="stat-box">GNOSIS: @character.TotalGnosis</div>
        <div class="stat-box">WILLPOWER: @character.TotalWillpower</div>
        <div class="stat-box">RANK: 1 (CLIATH)</div>
    </div>
</div>

@code {
    private W20Character character => BuilderService.CurrentCharacter;

    private async Task PrintSheet() => await JS.InvokeVoidAsync("window.print");

    private async Task DownloadJson()
    {
        var json = JsonSerializer.Serialize(character, new JsonSerializerOptions { WriteIndented = true });
        var filename = $"{character.Name}_W20_Record.json";
        await JS.InvokeVoidAsync("downloadFile", filename, json);
    }
}

<style>
    .export-actions { display: flex; gap: 20px; margin-bottom: 20px; justify-content: center; }
    .btn-terminal { background: #000; color: #ff3333; border: 1px solid #ff3333; padding: 10px 20px; cursor: pointer; font-family: monospace; font-weight: bold; box-shadow: 3px 3px 0px #8B0000; }
    .btn-terminal:hover { background: #ff3333; color: #000; }

    .printable-sheet { background: #050505; color: #d3d3d3; padding: 40px; border: 1px solid #333; font-family: 'Courier New', Courier, monospace; }
    .sheet-header { border-bottom: 4px double #8B0000; margin-bottom: 20px; padding-bottom: 10px; }
    .sheet-header h1 { color: #ff3333; margin: 0 0 10px 0; font-size: 1.5rem; }
    .header-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; font-size: 0.9rem; }

    .sheet-section { margin-bottom: 30px; border: 1px solid #222; padding: 15px; }
    .sheet-section h3 { background: #8B0000; color: #fff; margin: -15px -15px 15px -15px; padding: 5px 15px; font-size: 1rem; letter-spacing: 2px; }
    .sheet-section h4 { color: #8B0000; margin-top: 0; text-decoration: underline; font-size: 0.9rem; }

    .triple-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
    .double-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .col p { margin: 0 0 5px 0; font-size: 0.9rem; }

    .gift-list { display: flex; flex-wrap: wrap; gap: 10px; }
    .gift-tag { color: #00ff00; font-weight: bold; }

    .stats-footer { display: flex; justify-content: space-around; background: #111; }
    .stat-box { font-size: 1.2rem; font-weight: bold; color: #ff3333; }

    /* Print Styles */
    @@media print {
        .no-print { display: none !important; }
        body { background: #fff !important; color: #000 !important; }
        .printable-sheet { background: #fff !important; color: #000 !important; border: none !important; padding: 0 !important; }
        .sheet-section { border: 1px solid #000 !important; }
        .sheet-section h3 { background: #eee !important; color: #000 !important; border-bottom: 1px solid #000 !important; }
        .stat-box, .gift-tag, .sheet-header h1 { color: #000 !important; }
        .scanline-bg { background-image: none !important; }
    }
</style>